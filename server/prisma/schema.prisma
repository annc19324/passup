generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int            @id @default(autoincrement())
  email                 String         @unique
  password              String
  fullName              String
  phone                 String?
  address               String?
  role                  Role           @default(USER)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  avatar                String?
  addressDetail         String?
  district              String?
  province              String?
  ward                  String?
  lastPostAt            DateTime?
  postLimit             Int            @default(0)
  pushCount             Int            @default(0)
  subscriptionExpiresAt DateTime?
  subscriptionType      String         @default("FREE")
  background            String         @default("")
  status                String         @default("ACTIVE") // ACTIVE, BANNED
  resetCode             String?
  resetCodeExpiresAt    DateTime?
  conversationsAsUser1  Conversation[] @relation("User1Conversations")
  conversationsAsUser2  Conversation[] @relation("User2Conversations")
  messages              SentMessage[]
  notifications         Notification[]
  orders                Order[]        @relation("BuyerOrders")
  products              Product[]
  ratingsReceived       Rating[]       @relation("RevieweeRatings")
  ratingsGiven          Rating[]       @relation("ReviewerRatings")
  reportsMade           Report[]       @relation("Reporter")
  wishlists             Wishlist[]

  @@map("users")
}


model SystemSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

model BackgroundOption {
  id        Int      @id @default(autoincrement())
  name      String
  value     String
  type      String   @default("COLOR")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("background_options")
}

model Conversation {
  id            Int           @id @default(autoincrement())
  user1Id       Int
  user2Id       Int
  productId     Int?
  lastMessageAt DateTime      @default(now())
  createdAt     DateTime      @default(now())
  product       Product?      @relation(fields: [productId], references: [id])
  user1         User          @relation("User1Conversations", fields: [user1Id], references: [id])
  user2         User          @relation("User2Conversations", fields: [user2Id], references: [id])
  messages      SentMessage[]

  @@unique([user1Id, user2Id, productId])
  @@map("conversations")
}

model SentMessage {
  id             Int          @id @default(autoincrement())
  conversationId Int
  senderId       Int
  text           String
  image          String?
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id])

  @@map("messages")
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  slug      String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@map("categories")
}

model Product {
  id            Int            @id @default(autoincrement())
  title         String
  description   String
  price         Decimal        @db.Decimal(10, 2)
  images        String[]
  status        ProductStatus  @default(AVAILABLE)
  sellerId      Int
  categoryId    Int
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  slug          String?        @unique
  district      String?
  province      String?
  ward          String?
  addressDetail String?
  isHighlight   Boolean        @default(false)
  isPromoted    Boolean        @default(false)
  pushedAt      DateTime       @default(now())
  allowPickup   Boolean        @default(true)
  allowShip     Boolean        @default(false)
  shipPrice     String?
  stock         Int            @default(1)
  conversations Conversation[]
  orders        Order[]
  category      Category       @relation(fields: [categoryId], references: [id])
  seller        User           @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  wishlists     Wishlist[]

  @@map("products")
}

model Wishlist {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId Int
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("wishlists")
}

model Order {
  id              Int         @id @default(autoincrement())
  buyerId         Int
  productId       Int
  status          OrderStatus @default(PENDING)
  totalAmount     Decimal     @db.Decimal(10, 2)
  shippingPhone   String?
  shippingAddress String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  buyer           User        @relation("BuyerOrders", fields: [buyerId], references: [id])
  product         Product     @relation(fields: [productId], references: [id])
  rating          Rating?

  @@map("orders")
}

model Rating {
  id         Int      @id @default(autoincrement())
  orderId    Int      @unique
  reviewerId Int
  revieweeId Int
  rating     Int      @default(5)
  comment    String?
  createdAt  DateTime @default(now())
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reviewee   User     @relation("RevieweeRatings", fields: [revieweeId], references: [id])
  reviewer   User     @relation("ReviewerRatings", fields: [reviewerId], references: [id])

  @@map("ratings")
}

model Report {
  id          Int        @id @default(autoincrement())
  reporterId  Int
  targetType  ReportType
  targetId    Int
  reason      String     @db.VarChar(255)
  description String?
  status      String     @default("PENDING")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  reporter    User       @relation("Reporter", fields: [reporterId], references: [id])

  @@map("reports")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  content   String
  type      String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@map("notifications")
}

enum Role {
  USER
  ADMIN
}

enum ProductStatus {
  AVAILABLE
  RESERVED
  SOLD
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPING
  COMPLETED
  CANCELLED
}

enum ReportType {
  PRODUCT
  USER
}
